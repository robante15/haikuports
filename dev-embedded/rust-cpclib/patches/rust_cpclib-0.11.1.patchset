From f8c9bab627c0c58c29ce8ba247cca88187a3dbb0 Mon Sep 17 00:00:00 2001
From: PulkoMandy <pulkomandy@pulkomandy.tk>
Date: Thu, 14 May 2026 21:32:07 +0200
Subject: More reasonable stack size

1GB of stack is certainly not needed, and not allowed on Haiku anyways.

diff --git a/cpclib-basm/src/main.rs b/cpclib-basm/src/main.rs
index 384c12c..7a2d631 100644
--- a/cpclib-basm/src/main.rs
+++ b/cpclib-basm/src/main.rs
@@ -74,7 +74,7 @@ fn main() {
     use std::process::exit;
 
     let code = std::thread::Builder::new()
-        .stack_size(1024 * 1024 * 1024)
+        .stack_size(1024 * 1024)
         .spawn(basm)
         .unwrap()
         .join()
-- 
2.52.0

